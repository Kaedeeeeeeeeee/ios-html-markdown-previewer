    "security.html.safe.singleFile.message": {
      "comment": "Safe Preview status message for single HTML files.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scripts and external network resources are blocked. Relative assets are best effort for single files."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "脚本和外部网络资源已被阻止。单文件导入的相对资源为尽力支持。"
