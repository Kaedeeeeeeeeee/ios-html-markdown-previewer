        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "腳本和外部網路資源已被阻止。單檔匯入的相對資源為盡力支援。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スクリプトと外部ネットワークリソースはブロックされます。単一ファイル読み込みの相対リソースはベストエフォートです。"
          }
        }
      }
    },
